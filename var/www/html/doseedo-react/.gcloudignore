node_modules/
.git
*~*

# Large ONNX model binaries — served from the GCS bucket at
# /models/ and /static/models/, not packed into the nginx container.
# Including them here bloated the gcloud source upload to ~900MB and
# caused "No space left on device" on the Cloud Build staging dir.
public/models/
public/static/models/
public/static/
*.onnx
*.onnx.data

# Large WASM runtime in the build output (24MB) — served from GCS by the
# GCLB url-map before requests reach Cloud Run, so the container doesn't need it.
build/static/media/
