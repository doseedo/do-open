# Copy to .env.local and fill in. Do NOT commit .env.local.
# All REACT_APP_ vars from the CRA app become NEXT_PUBLIC_ here.

NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_GIT_SHA=

# Beta password gate (validated by app/api/auth/gate/route.ts).
# Server-only — DO NOT prefix with NEXT_PUBLIC_. The previous
# NEXT_PUBLIC_PROTECTED_PASSWORD / NEXT_PUBLIC_ADMIN_KEY shipped the
# value into the browser bundle; the new path moves the compare to a
# Node API route and sets an HttpOnly cookie on success.
PROTECTED_PASSWORD=

# Hugging Face — server-side only. Proxied by app/api/hf/route.ts so the
# token never ships to the browser bundle. Model IDs stay client-readable
# because they're not secrets and are picked per-feature.
HF_API_TOKEN=
NEXT_PUBLIC_HF_AUDIO_MODEL=
NEXT_PUBLIC_HF_TEXT_TO_MUSIC_MODEL=
NEXT_PUBLIC_HF_VOICE_MODEL=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=
NEXT_PUBLIC_SENTRY_RELEASE=

# Backend origins (used by next.config.js rewrites). Leave blank to use defaults.
NEXT_PUBLIC_AUTH_ORIGIN=
NEXT_PUBLIC_MODAL_ORIGIN=
NEXT_PUBLIC_FRAMER_ORIGIN=

# Chatbot (Modal vLLM / Qwen3-14B-AWQ). Server-only — used by
# app/api/chat/route.ts. DO NOT prefix with NEXT_PUBLIC_, that would
# leak the key to the browser bundle.
#   CHATBOT_ORIGIN  — defaults to the deployed Modal URL
#   VISION_ORIGIN   — defaults to the deployed Moondream Modal URL
#   VLLM_GATE_TOKEN — canonical bearer token (matches the Fly auth-service
#                     secret). VLLM_API_KEY is kept as a fallback alias.
CHATBOT_ORIGIN=
VISION_ORIGIN=
VLLM_GATE_TOKEN=
VLLM_API_KEY=

# Upstash Redis — used by /api/chat and /api/vision per-user rate limiting.
# Pull from the Upstash console (https://console.upstash.com → Database →
# REST API tab). Without these the limiter no-ops (allows all requests).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Clerk — publishable key only. CLERK_SECRET_KEY lives in Vercel env vars (server-only).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
