node_modules
.next
out
.env
.env.local
.env.*.local
*.tsbuildinfo
next-env.d.ts
.vercel
.DS_Store

# Un-ignore frontend image assets (root .gitignore blocks *.png, *.jpg,
# etc. to keep ML media out of the repo, but this Next.js app needs them).
!**/*.png
!**/*.jpg
!**/*.jpeg
!**/*.gif
!**/*.webp

# Un-ignore small client-side ONNX models that ship with the frontend
# bundle (rmsDemucs, mask refiner, etc.). Root .gitignore blocks *.onnx
# to keep training checkpoints out of the repo; these 100-600KB inference
# models need to be served to the browser.
!public/static/models/*.onnx
!public/static/models/*.onnx.data

# Re-ignore the 254MB mask UNet weights — too large for git (GitHub 100MB
# hard limit). Served from R2 / CDN at runtime.
public/static/models/mask_unet_v1_step15000.onnx
public/static/models/mask_unet_v1_step15000.onnx.data

# Local agent tooling (not part of repo)
.claude/
