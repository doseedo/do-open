{
  "input_dim": 200,
  "hidden_dim": 512,
  "num_semantic_features": 20,
  "num_locality_types": 3,
  "reconstruction_weight": 1.0,
  "locality_weight": 0.5,
  "sparsity_weight": 0.01,
  "learning_rate": 0.0001,
  "batch_size": 32,
  "dropout": 0.1,
  "weight_decay": 1e-05,
  "feature_activation": "relu",
  "normalize_features": true,
  "use_batch_norm": true,
  "residual_connections": false,
  "enable_weight_sparsity": false,
  "sparsity_ratio": 0.001,
  "initial_sparsity": 0.5,
  "target_sparsity": 0.001,
  "sparsity_warmup_epochs": 50,
  "sparsity_method": "topk"
}