              "musical_function": "Measures timing precision",
              "examples": {
                "human_feel": 0.4,
                "moderate": 0.7,
                "perfect": 1.0
              }
            },
            "electronic.filter_movement": {
              "type": "continuous",
              "default": 0.5,
              "description": "Spectral/filter movement (0.0=static, 1.0=dynamic)",
              "extraction": "spectral_variation_proxy",
              "range": [0.0, 1.0],
              "formula": "timbre_change_rate (proxy via velocity/cc)",
              "musical_function": "Estimates timbral modulation",
              "examples": {
                "static": 0.2,
                "moderate": 0.5,
                "dynamic": 0.9
              }
            },
            "electronic.arpeggio_density": {
              "type": "continuous",
              "default": 0.3,
              "description": "Arpeggio usage (0.0=none, 1.0=constant arpeggios)",
              "extraction": "arpeggio_pattern_detection",
              "range": [0.0, 1.0],
              "formula": "arpeggio_notes / total_notes",
              "musical_function": "Identifies arpeggiated patterns",
              "examples": {
                "pad_focused": 0.1,
                "moderate": 0.4,
                "arpeggio_heavy": 0.9
              }
            }
          }
        },

        "hiphop_specific": {
          "count": 2,
          "active": "when genre.primary == 'hiphop'",
          "parameters": {
            "hiphop.sample_based": {
              "type": "continuous",
              "default": 0.7,
              "description": "Sample-based structure (0.0=composed, 1.0=loop-based)",
              "extraction": "loop_repetition_analysis",
              "range": [0.0, 1.0],
              "formula": "looped_material / total_material",
              "musical_function": "Identifies loop-based production",
              "examples": {
                "composed": 0.2,
                "sample_based": 0.8,
                "heavy_loops": 0.95
              }
            },
            "hiphop.boom_bap_feel": {
              "type": "continuous",
              "default": 0.6,
              "description": "Boom-bap drum feel (0.0=trap/modern, 1.0=classic boom-bap)",
              "extraction": "drum_pattern_classification",
              "range": [0.0, 1.0],
              "formula": "boom_bap_pattern_score",
              "musical_function": "Categorizes drum style",
              "examples": {
                "trap": 0.1,
                "moderate": 0.5,
                "classic": 0.9
              }
            }
          }
        },

        "latin_specific": {
          "count": 2,
          "active": "when genre.primary == 'latin'",
          "parameters": {
            "latin.clave_pattern": {
              "type": "categorical",
              "options": ["none", "son_clave_2-3", "son_clave_3-2", "rumba_clave_2-3", "rumba_clave_3-2", "bossa_clave"],
              "default": "son_clave_2-3",
              "description": "Clave pattern type",
              "extraction": "clave_detection_algorithm",
              "range": null,
              "musical_function": "Identifies rhythmic foundation",
              "examples": {
                "salsa": "son_clave_2-3",
                "rumba": "rumba_clave_2-3",
                "bossa_nova": "bossa_clave"
              }
            },
            "latin.montuno_complexity": {
              "type": "continuous",
              "default": 0.5,
              "description": "Montuno pattern complexity (0.0=simple, 1.0=complex)",
              "extraction": "montuno_pattern_analysis",
              "range": [0.0, 1.0],
              "formula": "montuno_variation_score",
              "musical_function": "Measures piano montuno sophistication",
              "examples": {
                "simple": 0.2,
                "moderate": 0.5,
                "complex": 0.9
              }
            }
          }
        }
      }
    }
  },

  "dependencies": {
    "description": "Parameter dependencies and conditioning relationships",
    "level2_conditions_on_level1": {
      "harmony.*": ["genre.primary", "key.tonic", "key.mode"],
      "melody.*": ["key.tonic", "key.mode", "tempo.bpm"],
      "rhythm.*": ["tempo.bpm", "time_signature", "genre.primary"],
      "dynamics.*": ["energy.level"],
      "texture.*": ["complexity.overall", "energy.level"]
    },
    "level3_conditions_on_level1": {
      "jazz.*": ["genre.primary == 'jazz'"],
      "classical.*": ["genre.primary == 'classical'"],
      "rock.*": ["genre.primary == 'rock'"],
      "electronic.*": ["genre.primary == 'electronic'"],
      "hiphop.*": ["genre.primary == 'hiphop'"],
      "latin.*": ["genre.primary == 'latin'"]
    }
  },

  "validation_rules": {
    "description": "Cross-parameter validation constraints",
    "rules": [
      {
        "rule": "if rhythm.swing_amount > 0.6 then genre.primary should be 'jazz' or 'blues'",
        "type": "consistency_check"
      },
      {
        "rule": "if rock.power_chord_ratio > 0.7 then harmony.complexity should be < 0.5",
        "type": "musical_consistency"
      },
      {
        "rule": "if electronic.quantization > 0.9 then rhythm.groove_consistency should be > 0.8",
        "type": "consistency_check"
      },
      {
        "rule": "energy.level should correlate with dynamics.overall_level (r > 0.5)",
        "type": "correlation_check"
      },
      {
        "rule": "complexity.overall should correlate with harmony.complexity (r > 0.6)",
        "type": "correlation_check"
      }
    ]
  },

  "extraction_pipeline": {
    "description": "Order of parameter extraction from MIDI files",
    "stages": [
      {
        "stage": 1,
        "name": "Basic MIDI Analysis",
        "parameters": ["tempo.bpm", "time_signature", "key.tonic", "key.mode", "structure.form", "orchestration.instrument_count"]
      },
      {
        "stage": 2,
        "name": "Level 2 Feature Extraction",
        "parameters": ["harmony.*", "melody.*", "rhythm.*", "dynamics.*", "texture.*"]
      },
      {
        "stage": 3,
        "name": "Level 1 Aggregation",
        "parameters": ["energy.level", "complexity.overall", "genre.primary"]
      },
      {
        "stage": 4,
        "name": "Genre-Specific Analysis",
        "parameters": ["jazz.*", "classical.*", "rock.*", "electronic.*", "hiphop.*", "latin.*"],
        "condition": "based on genre.primary"
      }
    ]
  },

  "notes": {
    "design_philosophy": "Parameters are organized hierarchically to enable contextual generation. Level 1 provides global context, Level 2 provides universal musical dimensions, and Level 3 provides genre-specific nuances.",
    "backward_compatibility": "A legacy adapter will map the old 118-parameter API to this 50-parameter system. See parameter_migration_map.json for mappings.",
    "extensibility": "New genre-specific subcategories can be added to Level 3 without affecting Levels 1-2.",
    "performance": "Target extraction speed: <100ms per MIDI file for all 50 parameters."
  }
}
