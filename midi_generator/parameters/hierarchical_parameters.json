{
  "version": "2.0",
  "schema_version": "1.0.0",
  "created_date": "2025-11-20",
  "author": "Agent 01 - Parameter Consolidation Architect",
  "description": "Hierarchical 50-parameter system for multi-genre MIDI generation",
  "total_parameters": 50,
  "reduction_from_original": "118 -> 50 (57.6% reduction)",

  "levels": {
    "level1_global": {
      "name": "Global Context",
      "description": "High-level contextual parameters that condition all other parameters",
      "parameter_count": 8,
      "parameters": {
        "genre.primary": {
          "type": "categorical",
          "options": ["jazz", "classical", "rock", "electronic", "pop", "latin", "hiphop"],
          "default": "jazz",
          "description": "Primary musical genre",
          "extraction": "genre_classification",
          "range": null,
          "musical_function": "Determines which Level 3 genre-specific parameters are active",
          "examples": {
            "jazz": "bebop, swing, modal, fusion",
            "classical": "baroque, romantic, contemporary",
            "rock": "classic rock, progressive, metal"
          }
        },
        "tempo.bpm": {
          "type": "continuous",
          "options": null,
          "default": 120,
          "description": "Tempo in beats per minute",
          "extraction": "midi_meta_events or beat_tracking",
          "range": [40, 200],
          "musical_function": "Controls overall speed and energy",
          "examples": {
            "slow_ballad": 60,
            "medium_swing": 120,
            "fast_bebop": 240
          }
        },
        "time_signature": {
          "type": "categorical",
          "options": ["4/4", "3/4", "6/8", "5/4", "7/8", "12/8", "2/4"],
          "default": "4/4",
          "description": "Time signature",
          "extraction": "midi_meta_events",
          "range": null,
          "musical_function": "Defines metric structure",
          "examples": {
            "common_time": "4/4",
            "waltz": "3/4",
            "complex": "7/8"
          }
        },
        "key.tonic": {
          "type": "categorical",
          "options": ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"],
          "default": "C",
          "description": "Key tonic (root note)",
          "extraction": "key_detection_algorithm",
          "range": null,
          "musical_function": "Establishes tonal center",
          "examples": {
            "C_major": "C",
            "F#_minor": "F#"
          }
        },
        "key.mode": {
          "type": "categorical",
          "options": ["major", "minor", "dorian", "phrygian", "lydian", "mixolydian", "aeolian", "locrian"],
          "default": "major",
          "description": "Key mode/scale type",
          "extraction": "key_detection_algorithm",
          "range": null,
          "musical_function": "Defines scale and harmonic color",
          "examples": {
            "bright": "major, lydian",
            "dark": "minor, phrygian",
            "modal_jazz": "dorian, mixolydian"
          }
        },
        "energy.level": {
          "type": "continuous",
          "options": null,
          "default": 0.5,
          "description": "Overall energy level (0.0=calm, 1.0=intense)",
          "extraction": "aggregate(dynamics, tempo, texture.density)",
          "range": [0.0, 1.0],
          "formula": "0.3*dynamics.overall_level + 0.3*min(tempo/200, 1.0) + 0.4*texture.density",
          "musical_function": "High-level intensity measure",
          "examples": {
            "ballad": 0.2,
            "medium": 0.5,
            "intense_rock": 0.9
          }
        },
        "complexity.overall": {
          "type": "continuous",
          "options": null,
          "default": 0.5,
          "description": "Overall musical complexity (0.0=simple, 1.0=complex)",
          "extraction": "aggregate(harmony.complexity, melody.rhythmic_complexity)",
          "range": [0.0, 1.0],
          "formula": "0.5*harmony.complexity + 0.3*melody.rhythmic_complexity + 0.2*rhythm.syncopation",
          "musical_function": "High-level complexity measure",
          "examples": {
            "simple_pop": 0.2,
            "standard_jazz": 0.6,
            "free_jazz": 0.95
          }
        },
        "structure.form": {
          "type": "categorical",
          "options": ["AABA", "ABAC", "verse_chorus", "verse_chorus_bridge", "through_composed", "theme_variations", "sonata", "rondo"],
          "default": "AABA",
          "description": "Overall musical form structure",
          "extraction": "structure_analysis",
          "range": null,
          "musical_function": "Defines large-scale organization",
          "examples": {
            "jazz_standard": "AABA",
            "pop_song": "verse_chorus_bridge",
            "classical": "sonata"
          }
        }
      }
    },

    "level2_universal": {
      "name": "Universal Dimensions",
      "description": "Core musical dimensions that apply across all genres",
      "parameter_count": 20,
      "subcategories": {

        "harmony": {
          "count": 6,
          "parameters": {
            "harmony.chord_density": {
              "type": "continuous",
              "default": 4.0,
              "description": "Harmonic density (chords per measure × notes per chord)",
              "extraction": "chord_detection + voicing_analysis",
              "range": [1.0, 12.0],
              "formula": "chords_per_measure * avg_notes_per_chord",
              "musical_function": "Controls harmonic activity level",
              "examples": {
                "sparse": 2.0,
                "medium": 4.0,
                "dense": 8.0
              }
            },
            "harmony.complexity": {
              "type": "continuous",
              "default": 0.5,
              "description": "Harmonic complexity (0.0=triads, 1.0=extended chords)",
              "extraction": "analyze_chord_extensions",
              "range": [0.0, 1.0],
              "formula": "0.3*use_9ths + 0.3*use_11ths + 0.4*use_13ths",
              "musical_function": "Measures chord sophistication",
              "examples": {
                "simple": 0.2,
                "jazz_standard": 0.7,
                "modern_jazz": 0.9
              }
            },
            "harmony.chromaticism": {
              "type": "continuous",
              "default": 0.3,
              "description": "Chromatic alteration level (0.0=diatonic, 1.0=highly chromatic)",
              "extraction": "analyze_chromatic_notes",
              "range": [0.0, 1.0],
              "formula": "(tritone_sub_prob + modal_interchange_prob) / 2",
              "musical_function": "Measures departure from diatonic harmony",
              "examples": {
                "diatonic": 0.1,
                "moderate": 0.4,
                "bebop": 0.8
              }
            },
            "harmony.tension": {
              "type": "continuous",
              "default": 0.5,
              "description": "Harmonic tension/dissonance level (0.0=consonant, 1.0=dissonant)",
              "extraction": "dissonance_analysis",
              "range": [0.0, 1.0],
              "formula": "avg_dissonance_score across all chords",
              "musical_function": "Measures harmonic instability",
              "examples": {
                "consonant": 0.2,
                "moderate": 0.5,
                "atonal": 0.95
              }
            },
            "harmony.voicing_spread": {
              "type": "continuous",
              "default": 0.5,
              "description": "Chord voicing spread (0.0=close, 1.0=wide)",
              "extraction": "analyze_pitch_range_in_chords",
              "range": [0.0, 1.0],
              "formula": "avg(chord_range_semitones) / 36.0",
              "musical_function": "Controls vertical spacing of chord notes",
              "examples": {
                "close": 0.2,
                "medium": 0.5,
                "wide": 0.9
              }
            },
            "harmony.progression_predictability": {
              "type": "continuous",
              "default": 0.5,
              "description": "Chord progression predictability (0.0=random, 1.0=very predictable)",
              "extraction": "progression_pattern_entropy",
              "range": [0.0, 1.0],
              "formula": "1.0 - normalized_entropy(progression_sequence)",
              "musical_function": "Measures harmonic predictability",
              "examples": {
                "predictable": 0.8,
                "moderate": 0.5,
                "avant_garde": 0.1
              }
            }
          }
        },

        "melody": {
          "count": 5,
          "parameters": {
            "melody.note_density": {
              "type": "continuous",
              "default": 4.0,
              "description": "Melodic note density (notes per measure)",
              "extraction": "count_notes_per_measure",
              "range": [1.0, 16.0],
              "formula": "total_melody_notes / total_measures",
              "musical_function": "Controls melodic activity level",
              "examples": {
                "sparse": 2.0,
                "moderate": 4.0,
                "bebop": 12.0
              }
            },
            "melody.range_semitones": {
              "type": "integer",
              "default": 12,
              "description": "Melodic range in semitones",
              "extraction": "max(pitch) - min(pitch)",
              "range": [3, 36],
              "formula": "highest_note - lowest_note",
              "musical_function": "Measures melodic span",
              "examples": {
                "narrow": 8,
                "octave": 12,
                "wide": 24
              }
            },
            "melody.contour_smoothness": {
              "type": "continuous",
              "default": 0.7,
              "description": "Melodic contour smoothness (0.0=jagged, 1.0=smooth)",
              "extraction": "analyze_interval_sizes",
              "range": [0.0, 1.0],
              "formula": "stepwise_ratio * (1 - avg_leap_size/12)",
              "musical_function": "Measures melodic continuity",
              "examples": {
                "jagged": 0.3,
                "moderate": 0.6,
                "legato": 0.9
              }
            },
            "melody.rhythmic_complexity": {
              "type": "continuous",
              "default": 0.5,
              "description": "Melodic rhythmic complexity (0.0=simple, 1.0=complex)",
              "extraction": "rhythm_entropy_analysis",
              "range": [0.0, 1.0],
              "formula": "normalized_entropy(note_durations)",
              "musical_function": "Measures rhythmic variety in melody",
              "examples": {
                "simple": 0.2,
                "moderate": 0.5,
                "complex": 0.9
              }
            },
            "melody.repetition": {
              "type": "continuous",
              "default": 0.5,
              "description": "Melodic repetition level (0.0=through-composed, 1.0=highly repetitive)",
              "extraction": "motif_detection",
              "range": [0.0, 1.0],
              "formula": "repeated_motif_ratio",
              "musical_function": "Measures melodic recurrence",
              "examples": {
                "through_composed": 0.1,
                "moderate": 0.5,
                "ostinato": 0.95
              }
            }
          }
        },

        "rhythm": {
          "count": 5,
          "parameters": {
            "rhythm.subdivision": {
              "type": "categorical",
              "options": ["whole", "half", "quarter", "eighth", "triplet", "sixteenth", "quintuplet", "sextuplet"],
              "default": "eighth",
              "description": "Primary rhythmic subdivision",
              "extraction": "detect_smallest_duration",
              "range": null,
              "musical_function": "Defines temporal granularity",
              "examples": {
                "ballad": "quarter",
                "medium": "eighth",
                "bebop": "sixteenth"
              }
            },
            "rhythm.syncopation": {
              "type": "continuous",
              "default": 0.3,
              "description": "Syncopation level (0.0=on-beat, 1.0=highly syncopated)",
              "extraction": "off_beat_ratio",
              "range": [0.0, 1.0],
              "formula": "notes_on_off_beats / total_notes",
              "musical_function": "Measures rhythmic displacement",
              "examples": {
                "on_beat": 0.1,
                "moderate": 0.4,
                "funk": 0.8
              }
            },
            "rhythm.groove_consistency": {
              "type": "continuous",
              "default": 0.7,
              "description": "Groove consistency (0.0=loose, 1.0=tight)",
              "extraction": "timing_deviation_analysis",
              "range": [0.0, 1.0],
              "formula": "1.0 - normalized_std(note_timings)",
              "musical_function": "Measures rhythmic stability",
              "examples": {
                "loose": 0.3,
                "moderate": 0.7,
                "quantized": 0.99
              }
            },
            "rhythm.polyrhythm": {
              "type": "continuous",
              "default": 0.1,
              "description": "Polyrhythmic complexity (0.0=single rhythm, 1.0=complex polyrhythms)",
              "extraction": "cross_rhythm_detection",
              "range": [0.0, 1.0],
              "formula": "count_conflicting_rhythms / total_voices",
              "musical_function": "Measures rhythmic layering",
              "examples": {
                "simple": 0.0,
                "moderate": 0.3,
                "afrobeat": 0.8
              }
            },
            "rhythm.swing_amount": {
              "type": "continuous",
              "default": 0.67,
              "description": "Swing ratio (0.5=straight, 0.67=standard, 0.75=hard)",
              "extraction": "measure_swing_ratio",
              "range": [0.5, 0.75],
              "formula": "duration_ratio of paired eighth notes",
              "musical_function": "Controls swing feel",
              "examples": {
                "straight": 0.5,
                "medium_swing": 0.67,
                "hard_swing": 0.75
              }
            }
          }
        },

        "dynamics": {
          "count": 2,
          "parameters": {
            "dynamics.overall_level": {
              "type": "continuous",
              "default": 0.6,
              "description": "Overall dynamic level (0.0=pp, 1.0=ff)",
              "extraction": "mean(all_velocities) / 127",
              "range": [0.0, 1.0],
              "formula": "avg_velocity / 127",
              "musical_function": "Controls overall loudness",
              "examples": {
                "pianissimo": 0.2,
                "mezzo_forte": 0.6,
                "fortissimo": 0.9
              }
            },
            "dynamics.range": {
              "type": "continuous",
              "default": 0.3,
              "description": "Dynamic range (0.0=flat, 1.0=wide dynamics)",
              "extraction": "std(all_velocities) / 127",
              "range": [0.0, 1.0],
              "formula": "velocity_std / 127",
              "musical_function": "Controls dynamic variation",
              "examples": {
                "flat": 0.1,
                "moderate": 0.3,
                "expressive": 0.7
              }
            }
          }
        },

        "texture": {
          "count": 2,
          "parameters": {
            "texture.polyphony": {
              "type": "integer",
              "default": 4,
              "description": "Maximum simultaneous voices",
              "extraction": "max_simultaneous_notes",
              "range": [1, 12],
              "formula": "max(notes_at_time_t for all t)",
              "musical_function": "Measures vertical density",
              "examples": {
                "monophonic": 1,
                "quartet": 4,
                "orchestral": 10
              }
            },
            "texture.density": {
              "type": "continuous",
              "default": 5.0,
              "description": "Overall note density (notes per second across all tracks)",
              "extraction": "total_notes / duration_seconds",
              "range": [0.5, 20.0],
              "formula": "sum(all_notes) / total_duration",
              "musical_function": "Measures temporal fullness",
              "examples": {
                "sparse": 2.0,
                "moderate": 5.0,
                "dense": 15.0
              }
            }
          }
        }
      }
    },

    "level3_genre_specific": {
      "name": "Genre-Specific Details",
      "description": "Genre-specific parameters activated based on genre.primary",
      "parameter_count": 22,
      "subcategories": {

        "universal_orchestration": {
          "count": 5,
          "active": "always",
          "parameters": {
            "orchestration.instrument_count": {
              "type": "integer",
              "default": 5,
              "description": "Number of distinct instruments",
              "extraction": "count(distinct_midi_programs)",
