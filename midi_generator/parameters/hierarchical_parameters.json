              "musical_function": "Controls ensemble size",
              "examples": {
                "solo": 1,
                "combo": 5,
                "orchestra": 15
              }
            },
            "orchestration.register_balance": {
              "type": "continuous",
              "default": 0.5,
              "description": "Register balance (0.0=low-heavy, 0.5=balanced, 1.0=high-heavy)",
              "extraction": "low_notes_ratio / high_notes_ratio",
              "range": [0.0, 1.0],
