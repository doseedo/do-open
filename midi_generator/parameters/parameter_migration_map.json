  "merged_mappings": [
    {
      "old_parameters": [
        "harmony.voicing.density",
        "harmony.voicing.type"
      ],
      "new_parameter": "harmony.chord_density",
      "mapping_type": "merged",
      "formula": "chords_per_measure * avg_notes_per_chord",
      "justification": "Consolidates voicing information into single density measure",
      "transformation_function": "compute_chord_density(voicing_density, voicing_type)",
      "notes": "Aggregates vertical and horizontal harmonic density"
    },
    {
      "old_parameters": [
        "harmony.extensions.use_9ths",
        "harmony.extensions.use_11ths",
        "harmony.extensions.use_13ths"
      ],
      "new_parameter": "harmony.complexity",
      "mapping_type": "merged",
      "formula": "0.3 * use_9ths + 0.3 * use_11ths + 0.4 * use_13ths",
      "justification": "Three boolean flags consolidated into single complexity score",
      "transformation_function": "aggregate_chord_extensions(use_9ths, use_11ths, use_13ths)",
      "notes": "Higher-order extensions weighted more heavily"
    },
    {
      "old_parameters": [
        "harmony.substitution.tritone_probability",
        "harmony.substitution.modal_interchange_probability"
      ],
      "new_parameter": "harmony.chromaticism",
      "mapping_type": "merged",
      "formula": "(tritone_sub_prob + modal_interchange_prob) / 2",
      "justification": "Both parameters measure chromatic alteration",
      "transformation_function": "average_chromatic_techniques(tritone, modal_interchange)",
      "notes": "Represents overall chromatic sophistication"
    },
    {
      "old_parameters": [
        "melody.intervals.max_leap",
        "melody.intervals.stepwise_probability"
      ],
      "new_parameter": "melody.contour_smoothness",
      "mapping_type": "merged",
      "formula": "stepwise_prob * (1 - max_leap/24)",
      "justification": "Both parameters describe melodic continuity",
      "transformation_function": "compute_contour_smoothness(max_leap, stepwise_prob)",
      "notes": "Higher stepwise motion + smaller leaps = smoother contour"
    },
    {
      "old_parameters": [
        "dynamics.velocity.base",
        "drums.kick.velocity_min",
        "drums.kick.velocity_max"
      ],
      "new_parameter": "dynamics.overall_level",
      "mapping_type": "merged",
      "formula": "mean(all_velocities_across_instruments) / 127",
      "justification": "Instrument-specific velocities consolidated into overall level",
      "transformation_function": "compute_overall_dynamics(all_instrument_velocities)",
      "notes": "Normalized to 0.0-1.0 range"
    },
    {
      "old_parameters": [
        "dynamics.velocity.variation",
        "drums.kick.velocity_max - drums.kick.velocity_min"
      ],
      "new_parameter": "dynamics.range",
      "mapping_type": "merged",
      "formula": "std(all_velocities) / 127",
      "justification": "Velocity variation consolidated across instruments",
      "transformation_function": "compute_dynamic_range(all_velocities)",
      "notes": "Measures dynamic expressiveness"
    },
    {
      "old_parameters": [
        "texture.polyphonic.density",
        "texture.layering.count",
        "texture.vertical.density"
      ],
      "new_parameter": "texture.polyphony",
      "mapping_type": "merged",
      "formula": "max_simultaneous_notes",
      "justification": "Multiple texture density measures consolidated",
      "transformation_function": "compute_polyphony(midi_file)",
      "notes": "Simple max voice count"
    },
    {
      "old_parameters": [
        "texture.horizontal.density",
        "texture.register.spread",
        "texture.contrast.rate"
      ],
      "new_parameter": "texture.density",
      "mapping_type": "merged",
      "formula": "total_notes / duration_seconds",
      "justification": "Temporal activity measures consolidated",
      "transformation_function": "compute_note_density(midi_file)",
      "notes": "Overall temporal fullness"
    }
  ],

  "computed_mappings": [
    {
      "old_parameter": "melody.intervals.*",
      "new_parameter": "melody.range_semitones",
      "mapping_type": "computed",
      "formula": "max(melody_pitches) - min(melody_pitches)",
      "transformation_function": "compute_melodic_range(melody_track)",
      "notes": "Calculated from actual melody notes"
    },
    {
      "old_parameter": "melody.chromaticism.amount + melody.ornaments.probability",
      "new_parameter": "melody.note_density",
      "mapping_type": "computed",
      "formula": "notes_per_measure",
      "transformation_function": "count_notes_per_measure(melody_track)",
      "notes": "Direct count of melodic activity"
    },
    {
      "old_parameter": "rhythm.syncopation.probability + rhythm.subdivision.*",
      "new_parameter": "rhythm.subdivision",
      "mapping_type": "computed",
      "formula": "detect_smallest_duration()",
      "transformation_function": "detect_rhythmic_subdivision(midi_file)",
      "notes": "Categorical determination of temporal grid"
    },
    {
      "old_parameter": "instrumentation.ensemble.size",
      "new_parameter": "orchestration.instrument_count",
      "mapping_type": "computed",
      "formula": "count(distinct_midi_programs)",
      "transformation_function": "count_instruments(midi_file)",
      "notes": "Direct count of unique instruments"
    },
    {
      "old_parameter": "genre.rock.vibrato_probability + genre.rock.vibrato_depth",
      "new_parameter": "rock.distortion_level",
      "mapping_type": "computed",
      "formula": "velocity_intensity * accent_density",
      "transformation_function": "estimate_distortion_level(articulation_data)",
      "notes": "Proxy for timbral aggression"
    }
  ],

