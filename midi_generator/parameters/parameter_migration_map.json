{
  "version": "2.0",
  "migration_version": "1.0.0",
  "created_date": "2025-11-20",
  "author": "Agent 01 - Parameter Consolidation Architect",
  "description": "Complete mapping from 118 legacy parameters to 50 hierarchical parameters",
  "total_old_parameters": 118,
  "total_new_parameters": 50,
  "reduction_percentage": 57.6,

  "mapping_categories": {
    "direct_mapping": "1:1 mapping, parameter kept as-is or renamed",
    "merged_mapping": "N:1 mapping, multiple old parameters consolidated into one",
    "computed_mapping": "1:1 mapping via computation/transformation",
    "new_parameter": "New parameter computed from MIDI analysis",
    "dropped_parameter": "Parameter dropped (justification provided)"
  },

  "direct_mappings": [
    {
      "old_parameter": "harmony.voicing.spread",
      "new_parameter": "harmony.voicing_spread",
      "mapping_type": "direct",
      "transformation": "none",
      "notes": "Kept as-is, measures vertical spread of chord voicings"
    },
    {
      "old_parameter": "rhythm.swing.amount",
      "new_parameter": "rhythm.swing_amount",
      "mapping_type": "direct",
      "transformation": "none",
      "notes": "Kept as-is, critical for jazz feel"
    },
    {
      "old_parameter": "rhythm.syncopation.probability",
      "new_parameter": "rhythm.syncopation",
      "mapping_type": "direct",
      "transformation": "none",
      "notes": "Kept as-is, measures rhythmic displacement"
    },
    {
      "old_parameter": "bass.style.walking_probability",
      "new_parameter": "jazz.walking_bass",
      "mapping_type": "direct",
      "transformation": "moved to genre-specific",
      "notes": "Now activated only for jazz genre"
    },
    {
      "old_parameter": "genre.rock.power_chord_probability",
      "new_parameter": "rock.power_chord_ratio",
      "mapping_type": "direct",
      "transformation": "none",
      "notes": "Kept as-is, critical for rock/metal genres"
    },
    {
      "old_parameter": "articulation.duration.ratio",
      "new_parameter": "articulation.legato_ratio",
      "mapping_type": "direct",
