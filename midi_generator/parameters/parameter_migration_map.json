  "backward_compatibility": {
    "description": "Legacy API adapter for old parameter system",
    "adapter_class": "LegacyParameterAdapter",
    "methods": {
      "old_to_new": {
        "description": "Map old 118-parameter dict to new 50-parameter dict",
        "implementation": "Apply mappings from this file",
        "example": "new_params = adapter.old_to_new(old_params)"
      },
      "new_to_old": {
        "description": "Map new 50-parameter dict back to old 118-parameter dict (lossy)",
        "implementation": "Reverse mappings + defaults for dropped params",
        "example": "old_params = adapter.new_to_old(new_params)",
        "notes": "Lossy conversion - dropped parameters set to defaults"
      }
    },
    "deprecation_warnings": true,
    "support_timeline": "Legacy API supported for 6 months, then deprecated"
  },

  "validation": {
    "description": "Validation tests for migration accuracy",
    "test_cases": [
      {
        "test": "Direct mappings preserve values",
        "assertion": "old_params['rhythm.swing.amount'] == new_params['rhythm.swing_amount']"
      },
      {
        "test": "Merged mappings maintain semantic meaning",
        "assertion": "harmony_complexity reflects extension usage"
      },
      {
        "test": "Computed mappings are accurate",
        "assertion": "melody.range_semitones matches actual pitch range"
      },
      {
        "test": "New parameters are reasonable",
        "assertion": "0.0 <= energy.level <= 1.0 and correlates with tempo/dynamics"
      },
      {
        "test": "Genre-specific parameters activate correctly",
        "assertion": "jazz.* only present when genre.primary == 'jazz'"
      }
    ]
  },

  "implementation_notes": {
    "priority": "Implement in this order: direct mappings → computed mappings → merged mappings → new parameters",
    "testing": "Test each mapping category independently before integration",
    "performance": "Target: <100ms for full 118→50 conversion",
    "documentation": "Each transformation function must be documented with examples"
  }
}
