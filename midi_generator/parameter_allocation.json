  "quality_metrics": {
    "target_reconstruction_quality": {
      "mse": "<0.01",
      "r2_score": ">0.95",
      "correlation": ">0.90"
    },
    "target_interpretability": {
      "interpreted_ratio": ">0.60",
      "high_confidence_ratio": ">0.50",
      "musical_validity": ">0.85"
    },
    "target_redundancy": {
      "max_correlation_with_existing": "<0.90",
      "orthogonality_score": ">0.70"
    }
  },

  "usage_example": {
    "description": "How to use parameter allocation for modular discovery",
    "code_snippet": [
      "from midi_generator.modular_blueprint import ModularSemanticDiscoveryPipeline",
      "from pathlib import Path",
      "",
      "# Initialize pipeline",
      "pipeline = ModularSemanticDiscoveryPipeline(",
      "    corpus_dir=Path('data/midi_corpus'),",
      "    output_dir=Path('output/modular_discovery'),",
      "    parallel=True  # Use parallel training",
      ")",
      "",
      "# Run discovery",
      "results = pipeline.run()",
      "",
      "# Access discovered parameters",
      "print(f\"Discovered {results['total_parameters']} parameters\")",
      "",
      "# Parameter allocation matches this JSON:",
      "# Harmony: 30, Rhythm: 20, Form: 15, ",
      "# Orchestration: 25, Texture: 20, Cross: 10",
      "# Total: 120 interpretable parameters"
    ]
  },

