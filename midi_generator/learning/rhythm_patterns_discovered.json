  "locality_functions": {
    "tempo_invariant_transforms": [
      {
        "type": "AUGMENT",
        "description": "Rhythmic augmentation (slower tempo)",
        "factor_range": [1.0, 4.0],
        "preserves": ["relative_timing", "pattern_structure"],
        "varies": ["absolute_tempo"]
      },
      {
        "type": "DIMINUTION",
        "description": "Rhythmic diminution (faster tempo)",
        "factor_range": [1.0, 4.0],
        "preserves": ["relative_timing", "pattern_structure"],
        "varies": ["absolute_tempo"]
      },
      {
        "type": "TIME_SHIFT",
        "description": "Temporal offset",
        "shift_range": [-2.0, 2.0],
        "preserves": ["all_content"],
        "varies": ["absolute_position"]
      },
      {
        "type": "RETROGRADE",
        "description": "Reverse event sequence",
        "preserves": ["event_content", "durations"],
        "varies": ["temporal_order"]
      },
      {
        "type": "RHYTHMIC_QUANTIZE",
        "description": "Grid alignment",
        "grid_divisions": [4, 8, 16, 32],
        "preserves": ["approximate_timing"],
        "varies": ["microtiming"]
      }
    ]
  },
  "training_methodology": {
    "architecture": "SemanticFeatureEncoder with rhythm-specific head",
    "input_dimension": 200,
    "hidden_dimension": 512,
    "output_dimension": 20,
    "loss_components": [
