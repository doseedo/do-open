          "auto_labelable": true,
          "category": "harmony"
        },
        "harmony.tension": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Harmonic tension level based on dissonance",
          "extraction_method": "dissonance_analysis",
          "auto_labelable": false,
          "manual_labeling_required": true,
          "labeling_guidance": "0.0 = consonant/resolved, 0.5 = moderate tension, 1.0 = high dissonance",
          "category": "harmony"
        },
        "harmony.voicing_spread": {
          "type": "continuous",
          "range": [0, 48],
          "unit": "semitones",
          "description": "Average pitch range of chord voicings",
