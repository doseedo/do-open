          "auto_labelable": true,
          "category": "melody"
        },
        "melody.range_semitones": {
          "type": "integer",
          "range": [0, 60],
          "unit": "semitones",
          "description": "Pitch range of melody in semitones",
          "extraction_method": "max_pitch_minus_min_pitch",
          "auto_labelable": true,
          "category": "melody"
        },
        "melody.contour_smoothness": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "How smooth vs angular the melodic contour is",
          "extraction_method": "stepwise_vs_leap_ratio",
          "auto_labelable": false,
          "manual_labeling_required": true,
          "labeling_guidance": "0.0 = angular/jagged with large leaps, 0.5 = balanced, 1.0 = very smooth/stepwise",
          "category": "melody"
        },
        "melody.rhythmic_complexity": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Rhythmic complexity of the melody",
          "extraction_method": "rhythm_entropy_and_syncopation",
          "auto_labelable": true,
          "category": "melody"
        },
        "melody.repetition": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Degree of motif and phrase repetition",
          "extraction_method": "motif_repetition_analysis",
          "auto_labelable": true,
          "category": "melody"
        },
        "rhythm.subdivision": {
          "type": "categorical",
          "options": ["whole", "half", "quarter", "eighth", "sixteenth", "triplet", "sextuplet"],
