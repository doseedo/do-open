          "auto_labelable": true,
          "category": "rhythm"
        },
        "dynamics.overall_level": {
          "type": "continuous",
          "range": [0, 127],
          "unit": "midi_velocity",
          "description": "Average velocity/dynamic level",
          "extraction_method": "mean_midi_velocity",
          "auto_labelable": true,
          "category": "dynamics"
        },
        "dynamics.range": {
          "type": "continuous",
          "range": [0, 127],
          "unit": "midi_velocity",
          "description": "Dynamic range (variation in velocity)",
          "extraction_method": "velocity_std_dev_or_range",
          "auto_labelable": true,
          "category": "dynamics"
        },
        "texture.polyphony": {
          "type": "integer",
          "range": [1, 16],
          "unit": "voices",
          "description": "Maximum number of simultaneous voices",
          "extraction_method": "max_simultaneous_notes",
          "auto_labelable": true,
          "category": "texture"
        },
        "texture.density": {
          "type": "continuous",
          "range": [0.0, 32.0],
          "unit": "notes_per_second",
          "description": "Overall note density across all voices",
          "extraction_method": "total_notes_per_second",
          "auto_labelable": true,
          "category": "texture"
        }
      }
    },

