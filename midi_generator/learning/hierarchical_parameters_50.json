{
  "version": "2.0",
  "description": "50-parameter hierarchical system for multi-genre MIDI corpus training",
  "total_parameters": 50,
  "creation_date": "2025-11-20",
  "agent": "Agent 03: Metadata & Labeling Manager",

  "levels": {
    "level1_global": {
      "description": "Global Context - High-level musical decisions",
      "parameter_count": 8,
      "parameters": {
        "genre.primary": {
          "type": "categorical",
          "options": ["jazz", "classical", "rock", "electronic", "pop", "hip_hop", "latin", "metal"],
          "description": "Primary genre classification",
          "extraction_method": "genre_detection_algorithm",
          "auto_labelable": true,
          "example_values": {
            "jazz": "bebop, swing, modal",
            "classical": "baroque, romantic, contemporary"
          }
        },
        "tempo.bpm": {
          "type": "continuous",
          "range": [40, 200],
          "unit": "beats_per_minute",
          "description": "Tempo in beats per minute",
          "extraction_method": "midi_tempo_events_or_beat_tracking",
          "auto_labelable": true,
          "example_values": {
            "slow": 60,
            "medium": 120,
            "fast": 180
          }
        },
        "time_signature": {
          "type": "categorical",
          "options": ["4/4", "3/4", "6/8", "5/4", "7/8", "2/4", "12/8", "other"],
          "description": "Time signature of the piece",
          "extraction_method": "midi_meta_events",
          "auto_labelable": true
        },
        "key.tonic": {
          "type": "categorical",
          "options": ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"],
          "description": "Tonic pitch class of the key",
          "extraction_method": "krumhansl_schmuckler_key_detection",
          "auto_labelable": true
        },
        "key.mode": {
          "type": "categorical",
          "options": ["major", "minor", "dorian", "phrygian", "lydian", "mixolydian", "aeolian", "locrian"],
          "description": "Mode of the key",
          "extraction_method": "key_detection_algorithm",
          "auto_labelable": true
        },
        "energy.level": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Overall energy level (aggregate of dynamics + complexity)",
          "extraction_method": "aggregate_dynamics_and_complexity_metrics",
          "auto_labelable": false,
          "manual_labeling_required": true,
          "labeling_guidance": "0.0 = very calm/ambient, 0.5 = moderate energy, 1.0 = high energy/intense"
        },
        "complexity.overall": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Overall musical complexity (harmony + melody + rhythm)",
          "extraction_method": "aggregate_complexity_metrics",
          "auto_labelable": false,
          "manual_labeling_required": true,
          "labeling_guidance": "0.0 = simple/repetitive, 0.5 = moderate complexity, 1.0 = very complex/dense"
        },
        "structure.form": {
          "type": "categorical",
          "options": ["AABA", "ABAC", "verse_chorus", "verse_chorus_bridge", "sonata", "rondo", "through_composed", "free_form"],
          "description": "Structural form of the piece",
          "extraction_method": "structure_form_detection",
          "auto_labelable": true
        }
      }
    },

    "level2_universal": {
      "description": "Universal Dimensions - Core musical features applicable across genres",
      "parameter_count": 20,
      "parameters": {
        "harmony.chord_density": {
          "type": "continuous",
          "range": [0.0, 8.0],
          "unit": "chords_per_measure",
          "description": "Average number of chord changes per measure",
          "extraction_method": "chord_detection_and_counting",
          "auto_labelable": true,
          "category": "harmony"
        },
        "harmony.complexity": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Harmonic complexity based on chord extensions and alterations",
          "extraction_method": "analyze_chord_extensions_9ths_11ths_13ths",
          "auto_labelable": true,
          "category": "harmony"
        },
        "harmony.chromaticism": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Degree of chromatic notes and alterations",
