          "auto_labelable": false,
          "manual_labeling_required": true,
          "labeling_guidance": "0.0 = unpredictable/surprising, 0.5 = moderately predictable, 1.0 = very predictable/formulaic",
          "category": "harmony"
        },
        "melody.note_density": {
          "type": "continuous",
          "range": [0.0, 16.0],
          "unit": "notes_per_beat",
