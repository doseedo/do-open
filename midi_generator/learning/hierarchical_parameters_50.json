        "rhythm.syncopation": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Degree of syncopation (off-beat emphasis)",
          "extraction_method": "off_beat_note_ratio",
          "auto_labelable": true,
          "category": "rhythm"
        },
        "rhythm.groove_consistency": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Consistency of rhythmic groove (timing consistency)",
          "extraction_method": "timing_deviation_analysis",
          "auto_labelable": true,
          "category": "rhythm"
        },
        "rhythm.polyrhythm": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Presence of polyrhythmic elements",
          "extraction_method": "detect_conflicting_rhythms",
          "auto_labelable": true,
          "category": "rhythm"
        },
        "rhythm.swing_amount": {
          "type": "continuous",
          "range": [0.0, 1.0],
          "description": "Amount of swing feel (0=straight, 1=heavy swing)",
