# Default server configuration
#

server {
      listen 443 ssl http2;
      listen [::]:443 ssl http2;
      root /var/www/html/doseedo-react/build;
  

  #    listen 80;
   #   listen [::]:80;

      ssl_certificate /etc/ssl/certs/doseedo.com.crt;
      ssl_certificate_key /etc/ssl/private/doseedo.com_key.txt;
      ssl_trusted_certificate /etc/ssl/certs/doseedo_com.ca-bundle;

  
      ssl_stapling on;
      ssl_stapling_verify on;
      ssl_session_cache shared:le_nginx_SSL:10m;
      ssl_session_timeout 1440m;
      ssl_protocols TLSv1.2 TLSv1.3;
      access_log /var/log/nginx/access.log;
  
      add_header X-Frame-Options "SAMEORIGIN" always;
      add_header X-Content-Type-Options "nosniff" always;
      add_header X-XSS-Protection "1; mode=block" always;
      add_header Referrer-Policy "no-referrer-when-downgrade" always;
      add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  
      index index.html;
  
      # Server name for both 'www' and non-'www' versions
      server_name doseedo.com www.doseedo.com;
  
      ssl_session_cache shared:le_nginx_SSL:10m;
      access_log /var/log/nginx/access.log;
      client_body_timeout 300s;
      keepalive_timeout 65; 
      keepalive_requests 1000;
      client_header_timeout 300s;


      # Serve CSS and JS files with correct MIME types (excluding /static/)
      location ~ ^(?!/static/).*\.(css|js)$ {
          root /var/www/html;
          try_files $uri =404;
          types {
              text/css css;
              application/javascript js;
          }
      }

      # Serve static auth/info pages at clean URLs
      location = /login {
          root /var/www/html;
          try_files /login.html =404;
      }

      location = /register {
          root /var/www/html;
          try_files /login.html =404;
      }

      location = /forgotpassword {
          root /var/www/html;
          try_files /forgotpassword.html =404;
      }

      location = /reset-password {
          root /var/www/html;
          try_files /reset-password-form.html =404;
      }

      location = /about {
          root /var/www/html;
          try_files /about.html =404;
      }

      location = /privacy {
          root /var/www/html;
          try_files /privacy.html =404;
      }

      location = /terms {
          root /var/www/html;
          try_files /terms.html =404;
      }

      location = /plans {
          root /var/www/html;
          try_files /plans.html =404;
      }
      location = /home {
          proxy_pass https://heartwarming-friday-546447.framer.app/;
          proxy_set_header Host heartwarming-friday-546447.framer.app;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_set_header X-Forwarded-Proto $scheme;
          proxy_ssl_server_name on;
      }

  
      # Handle requests for validation files
      location /.well-known/ {
          root /var/www/html;
          allow all;
      }
  
      # Serve static files from React build
      location /static/ {
          root /var/www/html/doseedo-react/build;
          expires 1y;
          add_header Cache-Control "public, immutable";
      }

      # Serve assets (icons, images, etc.)
      location ^~ /assets/ {
          root /var/www/html;
          try_files $uri =404;
      }

    # Serve temp_videos with CORS headers

    location /temp_videos/ {

        alias /home/arlo/ScoreAI/temp_videos/;

        # Handle CORS preflight (OPTIONS)

        if ($request_method = 'OPTIONS') {

            add_header Access-Control-Allow-Origin "*";

            add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS";

            add_header Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Range";

            add_header Access-Control-Max-Age 3600;

            add_header Content-Length 0;

            return 204;

        }



        # Add CORS headers for actual requests

        add_header Access-Control-Allow-Origin "*" always;

        add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS" always;

        add_header Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Range" always;

        add_header Access-Control-Expose-Headers "Content-Length, Content-Range" always;

        add_header Accept-Ranges "bytes" always;



        try_files $uri =404;

    }



