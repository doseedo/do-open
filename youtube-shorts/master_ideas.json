  "music_modes": {
    "animation_drives_music": {
      "description": "Physics collisions trigger musical notes. Pitch from position, velocity from impact force.",
      "two_pass": true
    },
    "music_drives_animation": {
      "description": "Generate melody first. Each note onset triggers a physics event at a mapped position.",
      "two_pass": true
    },
    "parallel_sync": {
      "description": "Generate background music independently. Music accompanies the animation.",
      "two_pass": false
    }
