<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.doseedo.DoaeCodec</string>
    <key>CFBundleName</key>
    <string>DoaeCodec</string>
    <key>CFBundleDisplayName</key>
    <string>Doseedo Audio Engine Codec</string>
    <key>CFBundleExecutable</key>
    <string>DoaeCodec</string>
    <key>CFBundlePackageType</key>
    <string>BNDL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleSupportedPlatforms</key>
    <array><string>MacOSX</string></array>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Doseedo. All rights reserved.</string>

    <!-- Core Audio File Component registration -->
    <key>AudioComponents</key>
    <array>
        <dict>
            <!-- 'afil' = Audio File Component type (registered with Core Audio) -->
            <key>type</key>
            <string>afil</string>
            <!-- 'DOAE' = our file format subtype -->
            <key>subtype</key>
            <string>DOAE</string>
            <key>manufacturer</key>
            <string>Dose</string>
            <key>name</key>
            <string>Doseedo: DOAE Audio File Decoder</string>
            <key>description</key>
            <string>Decodes .doae latent audio files using Oobleck VAE</string>
            <key>version</key>
            <integer>65536</integer>
            <key>factoryFunction</key>
            <string>DoaeComponentFactory</string>
            <key>sandboxSafe</key>
            <false/>
        </dict>
    </array>

    <!-- UTI declaration so Finder recognises .doae files -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.doseedo.doae</string>
            <key>UTTypeDescription</key>
            <string>Doseedo Audio Engine File</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.audio</string>
                <string>public.data</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array><string>doae</string></array>
                <key>public.mime-type</key>
                <array><string>audio/x-doae</string></array>
            </dict>
        </dict>
    </array>
</dict>
</plist>
